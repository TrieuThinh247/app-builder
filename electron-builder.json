{
  "appId": "com.leandix.atlas",
  "productName": "Leandix Atlas",
  "directories": {
    "output": "dist"
  },
  "publish": {
    "provider": "github",
    "owner": "leandix-ai",
    "repo": "app-builder"
  },
  "extraMetadata": {
    "main": "out/electron/main.js"
  },
  "files": [
    "out/electron/**/*",
    "out/webview/**/*",
    "out/pdf-webview/**/*",
    "out/home-webview/**/*",
    "out/pdfjs/**/*",
    "out/tab-bar/**/*"
  ],
  "fileAssociations": [
    {
      "ext": "docx",
      "name": "Word Document",
      "description": "Open with Leandix Atlas",
      "role": "Editor"
    },
    {
      "ext": "pdf",
      "name": "PDF Document",
      "description": "Open with Leandix Atlas",
      "role": "Viewer"
    }
  ],
  "win": {
    "target": {
      "target": "nsis",
      "arch": ["x64", "ia32", "arm64"]
    },
    "icon": "../extension/media/atlas.ico"
  },
  "mac": {
    "target": [
      { "target": "dmg", "arch": ["x64", "arm64"] }
    ],
    "icon": "../extension/media/atlas-mac.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "../extension/media/bw.png",
    "category": "Office",
    "maintainer": "Leandix <info@leandix.com>"
  }
}
