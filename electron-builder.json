{
  "appId": "com.leandix.atlas",
  "productName": "Leandix Atlas",
  "directories": {
    "output": "dist"
  },
  "extraMetadata": {
    "main": "out/electron/main.js"
  },
  "files": [
    "out/electron/**/*",
    "out/webview/**/*",
    "out/pdf-webview/**/*",
    "out/home-webview/**/*",
    "out/pdfjs/**/*",
    "out/tab-bar/**/*"
  ],
  "win": {
    "target": {
      "target": "nsis",
      "arch": ["x64", "ia32", "arm64"]
    },
    "icon": "../extension/media/atlas.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "../extension/media/atlas-mac.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "../extension/media/leandix-icon.png",
    "category": "Office",
    "maintainer": "Leandix <info@leandix.com>"
  }
}
