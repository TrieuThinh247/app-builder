{
  "appId": "com.leandix.atlas",
  "productName": "Leandix Atlas",
  "directories": {
    "output": "dist"
  },
  "extraMetadata": {
    "main": "out/electron/main.js"
  },
  "files": [
    "out/electron/**/*",
    "out/webview/**/*",
    "out/pdf-webview/**/*",
    "out/home-webview/**/*",
    "out/pdfjs/**/*",
    "out/tab-bar/**/*"
  ],
  "win": {
    "target": "nsis",
    "icon": "../extension/media/atlas.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "../extension/media/atlas.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
