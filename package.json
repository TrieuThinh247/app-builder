{
  "name": "leandix-atlas",
  "displayName": "Leandix Atlas",
  "description": "A block-based rich text editor for .docx files, powered by Tiptap",
  "publisher": "leandix",
  "version": "1.0.6",
  "license": "MIT",
  "main": "./out/electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/leandix-ai/editor-extension.git"
  },
  "scripts": {
    "build:webview": "vite build --config vite.config-electron.ts",
    "build:home-webview": "vite build --config vite.config-home.ts",
    "build:electron-main": "node esbuild.electron-main.mjs",
    "build:electron-preload": "node esbuild.electron-preload.mjs",
    "copy:tab-bar": "node -e \"require('fs').cpSync('./src/tab-bar', './out/tab-bar', {recursive:true})\"",
    "build:electron": "npm run build:webview && npm run build:home-webview && npm run build:electron-main && npm run build:electron-preload && node copy-pdfjs.mjs && npm run copy:tab-bar",
    "electron:dev": "npm run build:electron && .\\node_modules\\electron\\dist\\electron.exe out/electron/main.js",
    "electron:dist": "npm run build:electron && npx electron-builder",
    "electron:dist:win": "npm run build:electron && npx electron-builder --win",
    "electron:dist:mac": "npm run build:electron && npx electron-builder --mac",
    "electron:dist:linux": "npm run build:electron && npx electron-builder --linux"
  },
  "dependencies": {
    "docx": "^9.0.2",
    "dom-serializer": "^2.0.0",
    "domutils": "^3.1.0",
    "htmlparser2": "^9.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.8.0",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-blockquote": "^3.22.5",
    "@tiptap/extension-bold": "^3.22.5",
    "@tiptap/extension-bubble-menu": "^3.22.5",
    "@tiptap/extension-bullet-list": "^3.22.5",
    "@tiptap/extension-code": "^3.22.5",
    "@tiptap/extension-code-block": "^3.22.5",
    "@tiptap/extension-code-block-lowlight": "^3.22.5",
    "@tiptap/extension-color": "^3.22.5",
    "@tiptap/extension-document": "^3.22.5",
    "@tiptap/extension-drag-handle": "^3.22.5",
    "@tiptap/extension-drag-handle-react": "^3.22.5",
    "@tiptap/extension-floating-menu": "^3.22.5",
    "@tiptap/extension-font-family": "^3.22.5",
    "@tiptap/extension-hard-break": "^3.22.5",
    "@tiptap/extension-heading": "^3.22.5",
    "@tiptap/extension-highlight": "^3.22.5",
    "@tiptap/extension-horizontal-rule": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-italic": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-list": "^3.22.5",
    "@tiptap/extension-ordered-list": "^3.22.5",
    "@tiptap/extension-paragraph": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-strike": "^3.22.5",
    "@tiptap/extension-subscript": "^3.22.5",
    "@tiptap/extension-superscript": "^3.22.5",
    "@tiptap/extension-table": "^3.22.5",
    "@tiptap/extension-text": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-text-style": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/extensions": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/suggestion": "^3.22.5",
    "@types/electron": "^1.6.10",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "lowlight": "^3.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  }
}
